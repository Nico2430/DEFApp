{
  "name": "defapp",
  "version": "1.0.3",
  "private": true,
  "productName": "DEFApp",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:installer": "npm run build && electron-builder --win nsis",
    "publish:github": "npm run build && electron-builder --win nsis --publish always",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "latest",
    "electron-updater": "^6.8.3",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "10.4.20",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "vite": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.defaberturas.defapp",
    "productName": "DEFApp",
    "publish": [
      {
        "provider": "github",
        "owner": "Nico2430",
        "repo": "DEFApp",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/logo-def.ico",
      "public/logo-def.png",
      "public/logo-emdaber.png"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/logo-def.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "description": "DEFApp - Gestión integral de aberturas de madera",
  "author": "DEF Aberturas"
}
